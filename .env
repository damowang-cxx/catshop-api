NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
API_PREFIX=api
COOKIE_SECRET=catshop-cookie-secret
RATE_LIMIT_MAX=200

JWT_SECRET=catshop-dev-jwt-secret
JWT_REFRESH_SECRET=catshop-dev-refresh-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_DEMO_TOKEN=test_admin_token

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/catshop
PRISMA_CONNECT_ON_BOOT=false
REDIS_URL=redis://localhost:6379
CLICKHOUSE_URL=http://localhost:8123
MEILISEARCH_URL=http://localhost:7700

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=catshop-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/avif
